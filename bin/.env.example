# Smoke / E2E test environment template.
# Copy to .env and fill in real values. The .env file is .gitignored.

# Full MCP endpoint URL.
NP_MCP_URL=https://your-site.example.com/wp-json/mcp/mcp-adapter-default-server

# Pre-built Basic auth header. Generate from a WP Application Password:
#   printf 'username:apppass' | base64
NP_MCP_AUTH=Basic CHANGE_ME
